{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "women-portoflio-pro",     // Cloudflare'de görünecek ad
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "main": ".open-next/worker.js"      // OpenNext'in oluşturduğu worker
}